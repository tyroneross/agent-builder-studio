# Required runtime
# Node.js 22+ is required because this package uses node:sqlite.

# Optional local model runtime
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_KNOWLEDGE_CHAT_MODEL=qwen3:14b
LOCAL_KNOWLEDGE_EMBED_MODEL=nomic-embed-text

# Optional local Omniparse SDK entrypoint.
# Leave blank to use internal text/RTF/PDF-best-effort parsing only.
OMNIPARSE_SDK_PATH=/Users/tyroneross/dev/git-folder/Omniparse/packages/sdk/dist/index.mjs

# Optional storage overrides.
LOCAL_KNOWLEDGE_VECTOR_STORE_PATH=data/store
LOCAL_KNOWLEDGE_DB_PATH=data/store/knowledge.db
