{
  "name": "agent-builder",
  "displayName": "Agent Builder Plugin Companion",
  "version": "0.3.0",
  "description": "Standalone companion skill for designing and evaluating agentic harnesses without installing the Agent Builder app.",
  "productRole": "plugin-companion",
  "companionFor": {
    "name": "Agent Builder App",
    "repository": "https://github.com/tyroneross/agent-builder"
  },
  "entrypoint": "SKILL.md",
  "manifests": {
    "claude": ".claude-plugin/plugin.json",
    "codex": ".codex-plugin/plugin.json"
  },
  "standalone": true,
  "bundledWithAppRepository": true,
  "requiredPaths": [
    "SKILL.md",
    "README.md",
    "examples",
    "references",
    ".claude-plugin/plugin.json",
    ".codex-plugin/plugin.json"
  ],
  "excludedAppPaths": [
    "app",
    "lib",
    "scripts",
    "sandbox",
    "tests",
    "generated",
    "agent-outputs",
    "node_modules"
  ],
  "license": "Apache-2.0",
  "author": {
    "name": "Tyrone Ross",
    "github": "tyroneross"
  }
}
