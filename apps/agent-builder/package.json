{
  "name": "agent-builder",
  "version": "0.3.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "serve": "next build && next start --port 3028",
    "build": "next build",
    "agent:scan": "node scripts/agent-scan.mjs",
    "agent:export": "node scripts/export-agent-package.mjs",
    "agent:doe": "node scripts/run-agent-doe.mjs",
    "agents:artifacts": "python3 scripts/run-artifact-agents.py",
    "agents:artifacts:doe": "python3 scripts/run-artifact-agents.py --doe",
    "agents:artifacts:doe50": "python3 scripts/run-artifact-agents.py --doe --doe-runs 50 --skip-models",
    "agents:artifacts:score": "python3 scripts/run-artifact-agents.py --doe --skip-models --score",
    "agents:artifacts:score50": "python3 scripts/run-artifact-agents.py --doe --doe-runs 50 --skip-models --score",
    "cos:gen": "node scripts/generate-chief-of-staff.mjs",
    "cos:run": "node scripts/run-chief-of-staff.mjs",
    "plan:run": "node scripts/run-plan.mjs",
    "sandbox:e2e": "node scripts/run-sandbox-e2e.mjs",
    "sandbox:score": "node scripts/run-sandbox-e2e.mjs --score --llm=fixture",
    "start": "next start",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@tyroneross/agent-spec": "*",
    "@tyroneross/local-llm": "*",
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "overrides": {
    "postcss": "^8.5.12"
  }
}
