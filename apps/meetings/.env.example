# Meetings app environment variables.
# Copy to .env.local (Next.js) or export in your shell before running
# `npm run dev --workspace meetings` / `npm test --workspace meetings`.

# --- Omniparse SDK (optional but recommended) ---------------------------
# Absolute path to your local Omniparse SDK entry file (index.mjs). Used to
# parse rich document types (.xlsx, .xls, .csv, .tsv, .ods, .xlsb, .pptx,
# .py, .pdf) into clean text before summarization.
#
# Required to enable Omniparse parsing. If unset (or the path doesn't
# exist), the app falls back to its internal text/RTF/PDF-best-effort/
# printable-text extraction and emits a warning naming this variable — it
# will NOT silently default to any hardcoded personal path.
OMNIPARSE_SDK_PATH=/absolute/path/to/Omniparse/packages/sdk/dist/index.mjs

# --- Ollama (optional; local model runtime) ------------------------------
# Base URL for a local Ollama server used for chat summarization and
# embeddings. Falls back to extractive/local-hash processing when
# unreachable or when preferOllama is disabled.
OLLAMA_BASE_URL=http://localhost:11434

# Chat model used to summarize meeting transcripts via Ollama.
MEETING_SUMMARY_MODEL=qwen3:14b

# Embedding model used for vector retrieval via Ollama.
MEETING_EMBED_MODEL=nomic-embed-text

# --- Local storage paths (optional) --------------------------------------
# Path (relative to the app root, or absolute) to the JSON vector/knowledge
# store file or directory. Defaults to
# agent-outputs/local-knowledge-agent/store/store.json
MEETING_VECTOR_STORE_PATH=agent-outputs/local-knowledge-agent/store

# Path (relative to the app root, or absolute) to the local SQLite
# knowledge database file. Defaults to
# agent-outputs/local-knowledge-agent/store/knowledge.db
MEETING_LOCAL_DB_PATH=agent-outputs/local-knowledge-agent/store/knowledge.db
